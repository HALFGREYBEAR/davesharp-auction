---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <header class="bar">
    <div class="bar-mark">
      Dave Sharp
      <span>Live Auction</span>
    </div>
    <div class="bar-live" id="liveFlag">
      <span class="dot"></span><span id="liveLabel">Loading</span>
    </div>
  </header>

  <main class="auction">
    <!-- Painting -->
    <section class="painting">
      <img id="paintingImg" alt="" style="display:none" />
      <div class="placeholder" id="paintingPlaceholder">Painting image</div>
    </section>

    <!-- Panel -->
    <section class="panel">
      <div class="eyebrow" id="phaseEyebrow">Auction</div>
      <h1 class="painting-title" id="paintingTitle">&nbsp;</h1>
      <div class="painting-meta" id="paintingMeta"></div>
      <p class="painting-story" id="paintingStory"></p>

      <div class="bidbox">
        <div class="bidbox-row" id="bidRow">
          <div>
            <div class="bid-label" id="bidLabel">Current bid</div>
            <div class="bid-amount" id="bidAmount">—</div>
            <div class="bid-sub" id="bidSub"></div>
          </div>
          <div style="text-align:right">
            <div class="bid-label" id="cdLabel">Closes in</div>
            <div class="countdown" id="countdown">—</div>
          </div>
        </div>

        <!-- Register: step 1 — details -->
        <div id="registerBlock" style="display:none">
          <div class="divider"></div>
          <div class="block-intro" id="registerIntro">Register to bid</div>
          <form id="registerForm">
            <div class="field-row">
              <div class="field">
                <label for="r-name">Your name</label>
                <input type="text" id="r-name" required />
              </div>
              <div class="field">
                <label for="r-phone">Phone (optional)</label>
                <input type="tel" id="r-phone" />
              </div>
            </div>
            <div class="field">
              <label for="r-email">Email</label>
              <input type="email" id="r-email" required />
            </div>
            <label class="commit">
              <input type="checkbox" id="r-commit" required />
              <span>I understand each bid I place is a binding commitment to buy if I win, payable by invoice.</span>
            </label>
            <button type="submit" class="btn" id="registerBtn">Send my code</button>
          </form>
        </div>

        <!-- Register: step 2 — verify code -->
        <div id="verifyBlock" style="display:none">
          <div class="divider"></div>
          <div class="block-intro">Enter your code</div>
          <p class="verify-note">
            We've emailed a 6-digit code to <b id="verifyEmail"></b>. Enter it to confirm.
          </p>
          <form id="verifyForm">
            <div class="field amount">
              <label for="v-code">6-digit code</label>
              <input type="text" id="v-code" inputmode="numeric" autocomplete="one-time-code"
                     maxlength="6" required />
            </div>
            <button type="submit" class="btn" id="verifyBtn">Verify &amp; continue</button>
          </form>
          <div class="verify-links">
            <a href="#" id="resendLink">Resend code</a>
            <a href="#" id="changeEmailLink">Use a different email</a>
          </div>
        </div>

        <!-- Bid form (verified + live) -->
        <div id="bidForm" style="display:none">
          <div class="divider"></div>
          <div class="bidder-tag" id="bidderTag"></div>
          <form id="form">
            <div class="field amount">
              <label for="f-amount" id="amountLabel">Your bid (£)</label>
              <input type="number" id="f-amount" required />
            </div>
            <button type="submit" class="btn" id="bidBtn">Place bid</button>
          </form>
        </div>

        <!-- State note (scheduled+verified / closed / draft) -->
        <div id="stateBlock" style="display:none">
          <div class="divider"></div>
          <p class="state-note" id="stateNote"></p>
        </div>

        <div class="msg" id="msg"></div>
      </div>

      <div class="rules" id="rules"></div>
    </section>
  </main>

  <script is:inline>
    (function () {
      var POLL_MS = 5000;
      var serverOffset = 0;
      var state = null;
      var me = { verified: false, firstName: '' };
      var regStep = 'details';        // 'details' | 'code'
      var pendingEmail = '';
      var bidArmed = false;
      var armTimer = null;
      var msgTimer = null;

      var $ = function (id) { return document.getElementById(id); };
      var money = function (n) { return '\u00A3' + Number(n || 0).toLocaleString('en-GB'); };
      function serverNow() { return Date.now() + serverOffset; }
      function nextMinBid() {
        if (!state) return 0;
        return Math.max(state.startingBid, (state.currentBid || 0) + state.minIncrement);
      }
      function show(id, on) { $(id).style.display = on ? 'block' : 'none'; }

      function showMsg(text, kind) {
        if (msgTimer) { clearTimeout(msgTimer); msgTimer = null; }
        var m = $('msg');
        m.textContent = text;
        m.className = 'msg show ' + kind;
      }
      function clearMsg() {
        if (msgTimer) { clearTimeout(msgTimer); msgTimer = null; }
        $('msg').className = 'msg';
      }

      function disarm() {
        bidArmed = false;
        if (armTimer) { clearTimeout(armTimer); armTimer = null; }
        var b = $('bidBtn');
        if (b) { b.classList.remove('armed'); b.textContent = 'Place bid'; }
      }

      // ---- rendering ----------------------------------------------------
      function render() {
        if (!state) return;
        var phase = state.phase;

        // Draft: nothing to show publicly.
        if (phase === 'draft') {
          $('liveFlag').className = 'bar-live';
          $('liveLabel').textContent = 'Coming soon';
          $('phaseEyebrow').textContent = 'Coming soon';
          $('paintingTitle').textContent = 'Auction coming soon';
          $('paintingMeta').textContent = '';
          $('paintingStory').textContent = '';
          show('bidRow', false);
          ['registerBlock', 'verifyBlock', 'bidForm'].forEach(function (i) { show(i, false); });
          show('stateBlock', true);
          $('stateNote').textContent = 'This auction has not been published yet. Please check back soon.';
          $('rules').innerHTML = '';
          return;
        }

        var p = state.painting || {};
        $('paintingTitle').textContent = p.title || 'Original Painting';
        $('paintingMeta').textContent = [p.size, p.medium].filter(Boolean).join('  \u00B7  ');
        $('paintingStory').textContent = p.story || '';

        var img = $('paintingImg');
        if (p.image && img.dataset.src !== p.image) {
          img.dataset.src = p.image;
          img.onerror = function () {
            img.style.display = 'none';
            $('paintingPlaceholder').style.display = 'block';
          };
          img.onload = function () {
            img.style.display = 'block';
            $('paintingPlaceholder').style.display = 'none';
          };
          img.src = p.image;
          img.alt = p.title || '';
        }

        var flag = $('liveFlag');
        if (phase === 'live') {
          flag.className = 'bar-live is-live';
          $('liveLabel').textContent = 'Auction live';
        } else if (phase === 'closed') {
          flag.className = 'bar-live';
          $('liveLabel').textContent = 'Auction ended';
        } else {
          flag.className = 'bar-live';
          $('liveLabel').textContent = 'Registration open';
        }

        var hasBids = (state.currentBid || 0) > 0;
        show('bidRow', true);
        $('bidAmount').textContent = hasBids ? money(state.currentBid) : money(state.startingBid);
        $('bidLabel').textContent = hasBids ? 'Current bid' : 'Starting bid';
        var sub = '';
        if (hasBids) {
          sub = state.bidCount + ' bid' + (state.bidCount === 1 ? '' : 's');
          if (state.youLead) sub += '  \u00B7  you are the high bidder';
          else if (state.leader) sub += '  \u00B7  high bidder ' + state.leader;
        } else {
          sub = phase === 'live' ? 'No bids yet — be the first' : 'No bids yet';
        }
        $('bidSub').textContent = sub;
        $('bidSub').style.color = state.youLead ? 'var(--ok)' : '';

        $('rules').innerHTML =
          'Minimum increment ' + money(state.minIncrement) + '  \u00B7  ' +
          'a bid in the final 10 minutes extends the close by 10 minutes<br/>' +
          'You verify your email once  \u00B7  the winning bid is invoiced directly  \u00B7  bids are binding';

        // Decide which block shows.
        var showReg = false, showVerify = false, showBid = false, showState = false;

        if (phase === 'closed') {
          showState = true;
          $('phaseEyebrow').textContent = 'Auction closed';
          $('cdLabel').textContent = 'Status';
          $('countdown').textContent = 'Ended';
          $('stateNote').textContent = hasBids
            ? 'Auction ended. Winning bid ' + money(state.currentBid) +
              (state.leader ? ' by ' + state.leader : '') + '. The winner has been emailed.'
            : 'This auction has ended with no bids.';
        } else if (phase === 'scheduled') {
          $('phaseEyebrow').textContent = 'Registration open';
          $('cdLabel').textContent = 'Opens in';
          if (me.verified) {
            showState = true;
            $('stateNote').textContent = "You're registered to bid. Bidding opens when the countdown reaches zero — your bids will be instant.";
          } else {
            showReg = (regStep === 'details');
            showVerify = (regStep === 'code');
            $('registerIntro').textContent = 'Register now — bidding opens soon';
          }
        } else { // live
          $('phaseEyebrow').textContent = 'Bidding open';
          $('cdLabel').textContent = 'Closes in';
          if (me.verified) {
            showBid = true;
            $('bidderTag').textContent = 'Bidding as ' + (me.firstName || 'you');
            // Only pre-fill the amount when it's empty — never overwrite a
            // value the bidder has typed, and never disarm on a poll.
            var amt = $('f-amount');
            if (!amt.value && document.activeElement !== amt) {
              amt.value = nextMinBid();
            }
            $('amountLabel').textContent = 'Your bid (£) — minimum ' + money(nextMinBid());
          } else {
            showReg = (regStep === 'details');
            showVerify = (regStep === 'code');
            $('registerIntro').textContent = 'Verify your email to bid';
          }
        }

        show('registerBlock', showReg);
        show('verifyBlock', showVerify);
        show('bidForm', showBid);
        show('stateBlock', showState);
      }

      function updateCountdown() {
        if (!state || state.phase === 'draft') return;
        var el = $('countdown');
        if (state.phase === 'closed') { el.textContent = 'Ended'; return; }
        var target = state.phase === 'scheduled'
          ? Date.parse(state.opensAt) : Date.parse(state.closesAt);
        var diff = target - serverNow();
        if (diff <= 0) { el.textContent = '00:00:00'; loadState(); return; }
        var s = Math.floor(diff / 1000);
        var d = Math.floor(s / 86400); s -= d * 86400;
        var h = Math.floor(s / 3600); s -= h * 3600;
        var m = Math.floor(s / 60); s -= m * 60;
        var pad = function (n) { return (n < 10 ? '0' : '') + n; };
        el.textContent = (d > 0 ? d + 'd ' : '') + pad(h) + ':' + pad(m) + ':' + pad(s);
        el.className = (state.phase === 'live' && diff < 10 * 60 * 1000) ? 'countdown urgent' : 'countdown';
      }

      // ---- data ---------------------------------------------------------
      async function loadState() {
        try {
          var res = await fetch('/api/state', { cache: 'no-store' });
          if (!res.ok) throw new Error('state ' + res.status);
          var s = await res.json();
          serverOffset = Date.parse(s.serverTime) - Date.now();
          state = s;
          render();
          updateCountdown();
        } catch (e) {
          $('liveLabel').textContent = 'Connection issue';
        }
      }
      async function loadMe() {
        try {
          var res = await fetch('/api/me', { cache: 'no-store' });
          if (res.ok) {
            var m = await res.json();
            me = { verified: !!m.verified, firstName: m.firstName || '' };
          }
        } catch (e) { /* treat as not verified */ }
      }

      // ---- register / verify -------------------------------------------
      async function submitRegister(e) {
        e.preventDefault();
        clearMsg();
        var btn = $('registerBtn');
        var payload = {
          name: $('r-name').value.trim(),
          email: $('r-email').value.trim(),
          phone: $('r-phone').value.trim(),
        };
        if (!$('r-commit').checked) { showMsg('Please tick the box to confirm bids are binding.', 'err'); return; }
        btn.disabled = true; btn.textContent = 'Sending…';
        try {
          var res = await fetch('/api/register', {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });
          var data = await res.json();
          if (data.ok) {
            pendingEmail = payload.email;
            $('verifyEmail').textContent = pendingEmail;
            regStep = 'code';
            render();
            $('v-code').focus();
          } else if (data.error === 'email_invalid') {
            showMsg('Please enter a valid email address.', 'err');
          } else if (data.error === 'name_required') {
            showMsg('Please enter your name.', 'err');
          } else if (data.error === 'email_failed') {
            showMsg('We could not send the code. Please check the address and try again.', 'err');
          } else if (data.error === 'not_open' || data.error === 'closed') {
            showMsg('Registration is not open for this auction.', 'err');
          } else {
            showMsg('Something went wrong. Please try again.', 'err');
          }
        } catch (err) {
          showMsg('Network error — please try again.', 'err');
        } finally {
          btn.disabled = false; btn.textContent = 'Send my code';
        }
      }

      async function submitVerify(e) {
        e.preventDefault();
        clearMsg();
        var btn = $('verifyBtn');
        var code = $('v-code').value.trim();
        btn.disabled = true; btn.textContent = 'Verifying…';
        try {
          var res = await fetch('/api/verify', {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email: pendingEmail, code: code }),
          });
          var data = await res.json();
          if (data.ok) {
            me = { verified: true, firstName: data.firstName || '' };
            regStep = 'details';
            $('v-code').value = '';
            showMsg('Email verified — you can bid.', 'ok');
            render();
          } else if (data.error === 'code_wrong') {
            showMsg('That code is not correct. Check the email and try again.', 'err');
          } else if (data.error === 'code_expired') {
            showMsg('That code has expired. Tap "Resend code" for a new one.', 'err');
          } else if (data.error === 'too_many_attempts') {
            showMsg('Too many attempts. Tap "Resend code" to start again.', 'err');
          } else if (data.error === 'no_code') {
            showMsg('No code on file — please request one again.', 'err');
          } else {
            showMsg('Something went wrong. Please try again.', 'err');
          }
        } catch (err) {
          showMsg('Network error — please try again.', 'err');
        } finally {
          btn.disabled = false; btn.textContent = 'Verify & continue';
        }
      }

      async function resendCode(e) {
        e.preventDefault();
        if (!pendingEmail) return;
        clearMsg();
        try {
          var res = await fetch('/api/register', {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              name: $('r-name').value.trim() || 'Bidder',
              email: pendingEmail,
              phone: $('r-phone').value.trim(),
            }),
          });
          var data = await res.json();
          if (data.ok) showMsg('A new code is on its way.', 'ok');
          else showMsg('Could not resend the code. Please try again.', 'err');
        } catch (err) {
          showMsg('Network error — please try again.', 'err');
        }
      }

      function changeEmail(e) {
        e.preventDefault();
        clearMsg();
        regStep = 'details';
        pendingEmail = '';
        render();
      }

      // ---- bidding ------------------------------------------------------
      async function submitBid(e) {
        e.preventDefault();
        var amount = Number($('f-amount').value);
        if (!Number.isFinite(amount) || amount <= 0) {
          showMsg('Enter a valid bid amount.', 'err');
          return;
        }
        // Two-tap confirm to prevent accidental binding bids. The armed
        // state holds for 10s — long enough for a calm second tap.
        if (!bidArmed) {
          bidArmed = true;
          var b = $('bidBtn');
          b.classList.add('armed');
          b.textContent = 'Tap again to confirm ' + money(amount);
          if (armTimer) clearTimeout(armTimer);
          armTimer = setTimeout(disarm, 10000);
          return;
        }
        disarm();
        clearMsg();
        var btn = $('bidBtn');
        btn.disabled = true; btn.textContent = 'Placing bid…';
        try {
          var res = await fetch('/api/bid', {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ amount: amount }),
          });
          var data = await res.json();
          if (data.ok) {
            showMsg('Bid placed — you are the high bidder at ' + money(data.currentBid) + '.', 'ok');
            msgTimer = setTimeout(clearMsg, 6000);
            // Clear so the next poll re-fills with the new minimum.
            $('f-amount').value = '';
          } else if (data.error === 'not_verified') {
            me = { verified: false, firstName: '' };
            regStep = 'details';
            showMsg('Your session expired — please register again.', 'err');
          } else if (data.error === 'outbid' || data.error === 'too_low') {
            showMsg('Bid not high enough — the current bid is now ' +
              money(data.currentBid || (data.minBid - state.minIncrement)) + '. Try again above.', 'err');
          } else if (data.error === 'over_cap') {
            showMsg('That exceeds the maximum bid of ' + money(data.maxBid) + '.', 'err');
          } else if (data.error === 'closed') {
            showMsg('The auction has closed.', 'err');
          } else if (data.error === 'not_open') {
            showMsg('Bidding is not open.', 'err');
          } else {
            showMsg('Sorry — your bid could not be placed. Please try again.', 'err');
          }
        } catch (err) {
          showMsg('Network error — please try again.', 'err');
        } finally {
          btn.disabled = false;
          if (!bidArmed) btn.textContent = 'Place bid';
          loadState();
        }
      }

      // ---- wire up ------------------------------------------------------
      $('registerForm').addEventListener('submit', submitRegister);
      $('verifyForm').addEventListener('submit', submitVerify);
      $('resendLink').addEventListener('click', resendCode);
      $('changeEmailLink').addEventListener('click', changeEmail);
      $('form').addEventListener('submit', submitBid);
      $('f-amount').addEventListener('input', disarm);

      (async function init() {
        await loadMe();
        await loadState();
        setInterval(loadState, POLL_MS);
        setInterval(updateCountdown, 1000);
      })();
    })();
  </script>
</Layout>
